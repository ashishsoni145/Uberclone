{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["rider", "driver"] }
      },
      "required": ["uid", "email"]
    },
    "Ride": {
      "title": "Ride",
      "description": "Ride booking details",
      "type": "object",
      "properties": {
        "riderId": { "type": "string" },
        "driverId": { "type": "string" },
        "status": { "type": "string", "enum": ["searching", "accepted", "ongoing", "completed", "cancelled"] },
        "pickup": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "destination": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["riderId", "status", "pickup", "destination"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride bookings"
    }
  }
}
